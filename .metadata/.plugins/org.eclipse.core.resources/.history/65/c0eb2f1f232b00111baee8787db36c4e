package com.example.demo.Contorller;

import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
public class Demo_1 {

	@PostMapping("/add-info/{name}/{Value}/{mo_Number}/{Price}")
	public String getadd(@PathVariable(value = "name") String name, @PathVariable(value = "Value") String Value,
			@PathVariable(value = "mo_Number") int mo_Number, @PathVariable(value = "Price") double Price) {
		return name+"\n"+Value+"\n"+mo_Number+"\n"+Price;
	}

}
