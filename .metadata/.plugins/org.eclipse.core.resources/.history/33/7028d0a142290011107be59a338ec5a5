package com.Connectivity.Actor.RestController;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RestController;

import com.Connectivity.Actor.Entity.Actor;
import com.Connectivity.Actor.Repositry.Actor_Repositry;

@RestController
public class Actor_Controller {

	@Autowired
	public Actor_Repositry rep;
	
	
	@PostMapping("/")
	public String add(@RequestBody Actor actor) throws InterruptedException
	{
		System.out.println("Adding Actor Name in Database Sucessfully...✅");
		Thread.sleep(3000);
		rep.save(actor);
		return actor.getActor_Name()+"Actor Name Add Suceesfullt";
	}
	
	@GetMapping("/get-data")
	public List<Actor> get()
	{
		return rep.findAll();
	}
	@DeleteMapping("delete/(id)")
	public String delete(@PathVariable (value="id") int id)
	{
		rep.deleteById(id);
		return "Deleted Id...⚠️";
	}
}
