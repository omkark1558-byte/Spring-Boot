package com.example.Books_Project.RestController;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import com.example.Books_Project.Entity.Book;
import com.example.Books_Project.Repositry.Books_Repositry;

@RestController
public class Books_Controller {


	private Books_Repositry book;
	
	public Books_Controller(Books_Repositry book)
	{
		this.book = book;
	}
	
	@PostMapping("/add-book")
	public String addbooks(@RequestBody Book bookobj) throws InterruptedException
	{
		System.out.println("Adding Book's In Databases....⚠️");
		Thread.sleep(3000);
		book.save(bokobj);
		return bookobj.getBook_Name()+"Book's Added Sucessfully..✅";
	}
	
	@GetMapping("/")
	public List<Book> get()
	{
		 return book.findAll();
		
	}
	@DeleteMapping("/delete/(id)")
	public String delete(@PathVariable(value="id") int id)
	{
		book.deleteById(id);
		return "Deleted Data...⚠️";
	}
}
